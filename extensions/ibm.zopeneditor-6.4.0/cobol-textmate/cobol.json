          "name": "keyword.identifers.cobol"
        },
        {
          "match": "(?<![-_])(?i:new)\\s+([a-zA-Z][a-zA-Z0-9\\$\\-\\._]*|[a-zA-Z])(?=\\.$)",
          "captures": {
