{
  "fileTypes": ["cbl", "cpy", "cob"],
  "name": "COBOL",
  "patterns": [
    {
      "match": "(^.{6})((\\*|\\/).{0,65})(.*$)",
      "captures": {
        "1": {
          "name": "entity.name.function.seqnum"
        },
        "2": {
          "name": "comment.line.cobol.fixed"
        },
        "3": {
          "name": "comment.line.cobol.fixed"
        },
        "4": {
          "name": "entity.name.function.seqnum"
        }
      }
    },
    {
      "description": "Captures single line statement for auto-complete",
      "match": "^(?i)(.{6})?\\s*((exec|execute)\\s+cics)\\s+(.*?)(end\\-exec\\.?).*",
      "captures": {
        "1": {
          "name": "entity.name.function.seqnum"
        },
        "2": {
          "name": "entity.name.function.cics"
        },
        "4": {
          "patterns": [
            { "include": "#cics-verb" },
            { "include": "#cics-parameter" },
            { "include": "#cics-parameter-value" },
            { "include": "#cics-comments" }
          ]
        },
        "5": {
          "name": "entity.name.function.cics"
        }
      }
    },
    { "include": "#exec-cics" },

    {
      "match": "(^.{6})(.{0,66})(.*$)",
      "captures": {
        "1": {
          "name": "entity.name.function.seqnum"
        },
        "2": {
          "patterns": [
            {
              "include": "#cobol-main"
            }
          ]
        },
        "3": {
          "name": "entity.name.function.seqnum"
        }
      }
    }
  ],
  "repository": {
    "exec-cics": {
      "name": "meta.block.cobol.cics",
      "begin": "^(.{6})?(?i:\\s*((exec|execute)\\s+cics))",
      "beginCaptures": {
        "1": { "name": "entity.name.function.seqnum" },
        "2": { "name": "entity.name.function.cics" }
      },
      "end": "^(?i)(.{6})?\\s*(.*?)\\s*(end\\-exec\\.?)",
      "endCaptures": {
        "1": { "name": "entity.name.function.seqnum" },
        "2": {
          "patterns": [
            { "include": "#cics-verb" },
            { "include": "#cics-parameter" },
            { "include": "#cics-parameter-value" }
          ]
        },
        "3": { "name": "entity.name.function.cics" }
      },

      "patterns": [
        {
          "match": "(^.{6})(.{0,66})(.*$)",
          "captures": {
            "1": {
              "name": "entity.name.function.seqnum"
            },
            "2": {
              "patterns": [
                { "include": "#cics-verb" },
                { "include": "#cics-parameter" },
                { "include": "#cics-parameter-value" },
                { "include": "#cics-comments" }
              ]
            },
            "3": {
              "name": "entity.name.function.seqnum"
            }
          }
        },
        { "include": "#cics-verb" },
        { "include": "#cics-parameter" },
        { "include": "#cics-parameter-value" },
        { "include": "#cics-comments" }
      ]
    },
    "cics-verb": {
      "patterns": [
        {
          "match": "(?i)(?:(define\\s+(composite|input)\\s+event|gds\\s+connect\\s+process|gds\\s+extract\\s+(attributes|process)|gds\\s+issue\\s+(abend|confirmation|error|prepare|signal)|(receive|send)\\s+map\\s+mappingdev|retrieve\\s+reattach\\s+event|send\\s+text\\s+(mapped|noedit)|web\\s+(endbrowse|read|readnext|startbrowse)\\s+(formfield|httpheader|queryparm)|web\\s+write\\s+httpheader)|(add\\s+subevent|address\\s+set|bif\\s+deedit|bif\\s+digest|build\\s+attach|change\\s+phrase|change\\s+password|change\\s+task|check\\s+acqprocess|check\\s+activity|check\\s+timer|connect\\s+process|define\\s+(activity|counter|dcounter|process|timer)|delete\\s+(activity|channel|container|counter|dcounter|event|timer)|deleteq\\s+(td|ts)|document\\s+(create|delete|insert|retrieve|set)|dump\\s+transaction|endbrowse\\s+(activity|container|event|process|timer)|enter\\s+tracenum|extract\\s+(attach|attributes|certificate|logonmsg|process|tcpip|tct|web)|fetch\\s+(any|child)|force\\s+timer|free\\s+child|gds\\s+(allocate|assign|free|receive|send|wait)|get\\s+(container|counter|dcounter)|getnext\\s+(activity|container|event|process|timer)|get64\\s+container|handle\\s+(abend|aid|condition)|ignore\\s+condition|inquire\\s+(activityid|container|event|process|timer)|invoke\\s+(application|service|webservice)|issue\\s+(abend|abort|add|confirmation|copy|disconnect|end|endfile|endoutput|eods|erase|eraseaup|error|load|note|pass|prepare|print|query|receive|replace|reset|send|signal|wait)|link\\s+(acqprocess|activity)|move\\s+container|pop\\s+handle|purge\\s+message|push\\s+handle|put\\s+container|put64\\s+container|query\\s+(channel|counter|dcounter|security)|readq\\s+(td|ts)|receive\\s+(map|partn)|remove\\s+subevent|request\\s+(encryptptkt|passticket)|reset\\s+(acqprocess|activity)|retrieve\\s+subevent|rewind\\s+(counter|dcounter)|run\\s+transid|send\\s+(control|map|page|partnset|text)|signal\\s+event|signon\\s+token|soapfault\\s+(add|create|delete)|spoolopen\\s+(input|output)|start\\s+(attach|brexit|channel)|startbrowse\\s+(activity|container|event|process|timer)|syncpoint\\s+rollback|test\\s+event|transform\\s+(datatojson|datatoxml|xmltodata|jsontodata)|update\\s+(counter|dcounter)|verify\\s+(password|phrase|token)|wait\\s+(convid|event|external|journalname|journalnum|signal|terminal)|web\\s+(close|converse)|web\\s+(extract|open|receive|retrieve|send)|write\\s+(journalname|journalnum|operator)|writeq\\s+(td|ts)|wsacontent\\s+(build|delete|get)|wsaepr\\s+create))",
          "captures": {
            "0": { "name": "entity.name.function.cics.verb" }
          }
        },
        {
          "match": "(?i)(?<=(exec|execute)\\s+cics\\s+)(?:[a-z]+)\\b",
          "captures": {
            "0": { "name": "entity.name.function.cics.verb" }
          }
        },
        {
          "match": "(?i)(ABEND|ACQUIRE|ADDRESS|ALLOCATE|ASKTIME|ASSIGN|CANCEL|CONVERSE|CONVERTTIME|DELAY|DELETE|DEQ|ENDBR|ENQ|FORMATTIME|FREE|FREEMAIN|FREEMAIN64|GETMAIN|GETMAIN64|JOURNAL|LINK|LOAD|MONITOR|POINT|POST|READ|READNEXT|READPREV|RECEIVE|RELEASE|RESETBR|RESUME|RETRIEVE|RETURN|REWRITE|ROUTE|RUN|SEND|SIGNOFF|SIGNON|SPOOLCLOSE|SPOOLREAD|SPOOLWRITE|START|STARTBR|SUSPEND|SYNCPOINT|UNLOCK|WAITCICS|WRITE|XCTL)",
          "captures": {
            "0": { "name": "entity.name.function.cics.verb" }
          }
        }
      ]
    },
    "cics-parameter": {
      "patterns": [
        {
          "name": "variable.parameter.cobol.cics",
          "match": "(?i)\\b(?!END\\-EXEC\\b)([a-zA-Z_][a-zA-Z0-9_-]*)(?=\\s*\\(|\\s|$)"
        }
      ]
    },
    "cics-comments": {
      "patterns": [
        {
          "match": "(\\*>.*$)",
          "name": "comment.line.modern"
        },
        {
          "match": "(\\*|\\/)(.*$)",
          "name": "comment.line.cobol.fixed"
        }
      ]
    },
    "cics-parameter-value": {
      "patterns": [
        {
          "name": "meta.variable.parameter.value.cobol.cics",
          "begin": "(\\()",
          "beginCaptures": {
            "0": { "name": "keyword.start.bracket.cobol" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "keyword.end.bracket.cobol" }
          },
          "patterns": [
            {
              "name": "string.quoted.single.cobol",
              "match": "('[^']*')"
            },
            {
              "name": "string.quoted.double.cobol",
              "match": "(\"[^\"]*\")"
            },
            {
              "name": "constant.numeric.cobol",
              "match": "\\b\\d+\\b"
            }
          ]
        }
      ]
    },

    "cobol-main": {
      "patterns": [
        {
          "match": "(?:^|\\s+)(?i:\\$\\s*set\\s+)(ilusing.*)$",
          "captures": {
            "0": {
              "name": "comment.line.set.cobol"
            },
            "1": {
              "name": "keyword.control.import"
            },
            "2": {
              "name": "comment.line.set.cobol"
            }
          }
        },
        {
          "match": "(?:^|\\s+)(?i:\\$\\s*set\\s)((?i:01SHUFFLE|64KPARA|64KSECT|AUXOPT|CHIP|DATALIT|EANIM|EXPANDDATA|FIXING|FLAG-CHIP|MASM|MODEL|OPTSIZE|OPTSPEED|PARAS|PROTMODE|REGPARM|SEGCROSS|SEGSIZE|SIGNCOMPARE|SMALLDD|TABLESEGCROSS|TRICKLECHECK|\\s)+).*$",
          "captures": {
            "0": {
              "name": "comment.line.set.cobol.1"
            },
            "1": {
              "name": "invalid.illegal.directive"
            },
            "2": {
              "name": "comment.line.set.cobol.2"
            }
          }
        },
        {
          "match": "(?:^|\\s+)(?i:\\$\\s*set\\s|>>cbl\\s)(.*)$",
          "captures": {
            "0": {
              "name": "comment.line.set.cobol"
            },
            "1": {
              "name": "variable.cobol"
            },
            "2": {
              "name": "comment.line.set.cobol"
            }
          }
        },
        {
          "match": "\\$(?i:if|else|then|display|xfd|end)(.*$)",
          "name": "meta.preprocessor"
        },
        {
          "match": "(?:^|\\s+)>>(?i:if|else|elif|end-if)(?:$|\\s.*$)",
          "name": "invalid.illegal.cobol"
        },
        {
          "match": "(\\*>.*$)",
          "name": "comment.line.modern"
        },
        {
          "match": "(#)([0-9a-zA-Z][a-zA-Z\\-0-9]+)",
          "name": "meta.symbol.cobol.forced"
        },
        {
          "match": "((?<![-_])((?i:installation|author|source-computer|object-computer|date-written|security|date-compiled)\\.)(.*))",
          "captures": {
            "1": {
              "name": "keyword.verb.cobol"
            },
            "2": {
              "name": "keyword.verb.cobol"
            },
            "3": {
              "name": "comment.line.cobol.ignored"
            }
          },
          "end": "(\\.)"
        },
        {
          "match": "(?<=(\\(|\\[))((\\-\\+)*[0-9 ,\\.\\+\\-\\*\\/]+)(?=(\\)|\\]))",
          "name": "constant.numeric.cobol",
          "captures": {
            "1": {
              "name": "keyword.start.bracket.cobol"
            },
            "2": {
              "name": "constant.numeric.cobol"
            },
            "3": {
              "name": "keyword.end.bracket.cobol"
            }
          },
          "comment": "simple numerics in () and []"
