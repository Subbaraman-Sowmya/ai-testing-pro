            },
            {
              "include": "source.sql"
            }
          ],
          "end": "(?i:end\\-exec)",
          "endCaptures": "string.quoted.cobol.sqlims"
        },
        {
          "begin": "(?i:exec\\s+ado)",
          "name": "string.quoted.cobol.ado",
          "patterns": [
            {
              "match": "(\\:([a-zA-Z\\-])*)",
              "name": "variable.cobol"
            },
            {
              "include": "source.sql"
            }
          ],
          "end": "(?i:end\\-exec)",
          "endCaptures": "string.quoted.cobol.ado"
        },
        {
          "begin": "(?i:exec\\s+html)",
