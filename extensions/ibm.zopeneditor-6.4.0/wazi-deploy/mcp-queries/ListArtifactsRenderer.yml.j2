---
# List deployed artifacts with environment name, deploy timestamp, application name (and version if any) and deployed package path
# Command: wazideploy-evidence -q ListDeployedArtifacts r
{%- if artifact_name is defined %} artifact_name={{artifact_name}}{% endif %}
{%- if artifact_type is defined %} artifact_type={{artifact_type}}{% endif %}
{%- if status is defined %} status={{status}}{% endif %}
{%- if environment_name is defined %} environment_name={{environment_name}}{% endif %}
{%- if application_name is defined %} application_name={{application_name}}{% endif %}
{%- if application_version is defined %} application_version={{application_version}}{% endif %}
{%- if package_path is defined %} package_path={{package_path}}{% endif %}
{%- if deployed_before is defined %} deployed_before={{deployed_before}}{% endif %}
{%- if deployed_after is defined %} deployed_after={{deployed_after}}{% endif %}
{% for artifact in results -%}
---
artifact: {{artifact.name}}.{{artifact.type}}
environments:
{%- for env in artifact.ymli_data %}
- environment_name: {{env.environment_name}}
  deploy_timestamp: {{env["deploy_timestamp|last"]}}
  application_name: {{env["name|last"]}}
  {%- if env["version|last"] is defined %}
  application_version: {{env["version|last"]}}{% endif %}
  package_path: {{env["path|last"]}}
{%- endfor %}
{% endfor %}