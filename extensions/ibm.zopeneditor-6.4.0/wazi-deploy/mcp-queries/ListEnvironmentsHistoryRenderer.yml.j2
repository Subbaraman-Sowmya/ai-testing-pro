---
# List environments with deployed artifacts, deploy date, application name (and version if any) and package path
# Command: wazideploy-evidence -q ListEnvironments r
{%- if package_path is defined %} package_path={{package_path}}{% endif %}
{%- if artifact_name is defined %} artifact_name={{artifact_name}}{% endif %}
{%- if artifact_type is defined %} artifact_type={{artifact_type}}{% endif %}
{%- if application_name is defined %} application_name={{application_name}}{% endif %}
{%- if application_version is defined %} application_version={{application_version}}{% endif %}
{%- if environment_name is defined %} environment_name={{environment_name}}{% endif %}
{%- if status is defined %} status={{status}}{% endif %}
{%- if deployed_before is defined %} deployed_before={{deployed_before}}{% endif %}
{%- if deployed_after is defined %} deployed_after={{deployed_after}}{% endif %} history=true
{% for environment in results -%}
---
environment_name: {{environment.environment_name}}
artifacts:
{%- for artifact in environment.ymli_data %}
- artifact: {{artifact.name}}.{{artifact.type}}
  deployments:
  {%- for deployment in artifact.ymli_data %}
  - deploy_timestamp: {{deployment.deploy_timestamp}}
    application_name: {{deployment["name|last"]}}
    {%- if deployment["version|last"] is defined %}
    application_version: {{deployment["version|last"]}}{% endif %}
    package_path: {{deployment["path|last"]}}
  {%- endfor %}
{%- endfor %}
{% endfor %}