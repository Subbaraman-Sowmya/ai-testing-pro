---
# List deployments with deploy timestamp, evidence file path, application name and version, environment name, package path and status
# Command: wazideploy-evidence -q ListDeployments r
{%- if status is defined %} status={{status}}{% endif %}
{%- if artifact_name is defined %} artifact_name={{artifact_name}}{% endif %}
{%- if artifact_type is defined %} artifact_type={{artifact_type}}{% endif %}
{%- if environment_name is defined %} environment_name={{environment_name}}{% endif %}
{%- if package_path is defined %} package_path={{package_path}}{% endif %}
{%- if application_name is defined %} application_name={{application_name}}{% endif %}
{%- if application_version is defined %} application_version={{application_version}}{% endif %}
{%- if deployed_before is defined %} deployed_before={{deployed_before}}{% endif %}
{%- if deployed_after is defined %} deployed_after={{deployed_after}}{% endif %}
{% for deployment in results -%}
---
deploy_timestamp: {{deployment.deploy_timestamp}}
evidence_file_path: {{deployment["ymli_folder|first"]}}{{deployment["ymli_file|first"]}}
environment_name: {{deployment["environment_name|first"]}}
application_name: {{deployment["name|first"]}}
{%- if deployment["version|first"] is defined %}
application_version: {{deployment["version|first"]}}{% endif %}
package_path: {{deployment["path|first"]}}
status: {{deployment["status|first"]}}
artifacts:
{%- for artifact in deployment.ymli_data %}
- {{artifact.name}}.{{artifact.type}}
{%- endfor %}
{% endfor %}