---
# List environments with deployed artifacts, deploy date, application name (and version if any) and package path
select:
  ymli_category~: ^ activities:[0-9]+ actions:[0-9]+ steps:[0-9]+ artifacts:[0-9]+ $
  name: '{{artifact_name | default("*")}}'
  {% if artifact_type is defined %}type: '{{artifact_type}}'{% endif %}
  ymli_parent:
    step_result:
      status: '{{status | default("Ok")}}'
    ymli_parent:
      ymli_level: 0
      metadata:
        name: '{{application_name | default("*")}}'
        {% if application_version is defined %}version: '{{application_version}}'{% endif %}
        annotations:
          environment_name: '{{environment_name | default("*")}}'
          {% if deployed_before is defined %}deploy_timestamp<: '{{deployed_before}}'{% endif %}
          {% if deployed_after is defined %}deploy_timestamp>=: '{{deployed_after}}'{% endif %}
          package:
            path: '{{package_path | default("*")}}'
output:
  fields:
    name: group 2
    type: group 2
    ymli_parent:
      ymli_parent:
        ymli_parent:
          ymli_parent:
            metadata:
              name: last
              version: last
              annotations:
                environment_name: group 1
                {% if history is defined and history|lower != "false" %}
                deploy_timestamp: group 3
                {%- else %}
                deploy_timestamp: last
                {%- endif %}
                package:
                  path: last
{% if history is defined and history|lower != "false" %}
renderer: ListEnvironmentsHistoryRenderer.yml.j2
# {% else %}
renderer: ListEnvironmentsRenderer.yml.j2
# {% endif %}
