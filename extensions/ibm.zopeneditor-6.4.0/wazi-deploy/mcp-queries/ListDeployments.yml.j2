---
# List deployments with deploy timestamp, evidence file path, application name and version, environment name, package path and status
select:
  ymli_category~: ^ activities:[0-9]+ actions:[0-9]+ steps:[0-9]+ artifacts:[0-9]+ $
  name: '{{artifact_name | default("*") }}'
  {% if artifact_type is defined %}type: '{{artifact_type}}'{% endif %}
  ymli_parent:
    ymli_level: 0
    status: '{{status | default("Ok")}}'
    metadata:
      name: '{{application_name | default("*")}}'
      {% if application_version is defined %}version: '{{application_version}}'{% endif %}
      annotations:
        environment_name: '{{environment_name | default("*")}}'
        {% if deployed_before is defined %}deploy_timestamp<: '{{deployed_before}}'{% endif %}
        {% if deployed_after is defined %}deploy_timestamp>=: '{{deployed_after}}'{% endif %}
        package:
          path: '{{package_path | default("*")}}'
output:
  fields:
    name: group 2
    type: group 2
    ymli_folder: first
    ymli_file: first
    ymli_parent:
      ymli_parent:
        ymli_parent:
          ymli_parent:
            status: first
            metadata:
              name: first
              version: first
              annotations:
                environment_name: first
                deploy_timestamp: group -1
                package:
                  path: first
renderer: ListDeploymentsRenderer.yml.j2
