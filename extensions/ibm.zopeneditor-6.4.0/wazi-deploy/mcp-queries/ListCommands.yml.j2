---
# List step commands with step name, status, deploy date, environment name, package path, application name and version
select:
  ymli_category~: ^ activities:[0-9]+ actions:[0-9]+ steps:[0-9]+ step_result results:[0-9]+ results $
  command: '{{filter | default("*")}}'
  ymli_parent:
    status: '{{status | default("*")}}'
    ymli_parent:
      ymli_parent:
        name: '{{step_name | default("*")}}'
        ymli_parent:
          ymli_parent:
            ymli_parent:
              ymli_level: 0
              metadata:
                name: '{{application_name | default("*")}}'
                {% if application_version is defined %}version: '{{application_version}}'{% endif %}
                annotations:
                  environment_name: '{{environment_name | default("*")}}'
                  {% if deployed_before is defined %}deploy_timestamp<: '{{deployed_before}}'{% endif %}
                  {% if deployed_after is defined %}deploy_timestamp>=: '{{deployed_after}}'{% endif %}
                  package:
                    path: '{{package_path | default("*")}}'
output:
  limit: {{limit | default("0")}}
  fields:
    command: yes
    ymli_parent:
      status: yes
      ymli_full_location: yes
      ymli_parent:
        ymli_parent:
          name: yes
          ymli_parent:
            ymli_parent:
              ymli_parent:
                metadata:
                  name: first
                  version: first
                  annotations:
                    environment_name: first
                    deploy_timestamp: group -1
                    package:
                      path: first
renderer: ListCommandsRenderer.yml.j2
