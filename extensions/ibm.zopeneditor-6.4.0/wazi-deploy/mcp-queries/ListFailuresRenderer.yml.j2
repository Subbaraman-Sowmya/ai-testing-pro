---
# List failures during deployment with deploy timestamp, environment name, location and detailed info
# Command: wazideploy-evidence -q ListFailures r
{%- if environment_name is defined %} environment_name={{environment_name}}{% endif %}
{%- if package_path is defined %} package_path={{package_path}}{% endif %}
{%- if application_name is defined %} application_name={{application_name}}{% endif %}
{%- if application_version is defined %} application_version={{application_version}}{% endif %}
{%- if deployed_before is defined %} deployed_before={{deployed_before}}{% endif %}
{%- if deployed_after is defined %} deployed_after={{deployed_after}}{% endif %}
{%- if limit is defined %} limit={{limit}}{% endif %}
{% for deployment in results -%}
---
deploy_timestamp: {{deployment.deploy_timestamp}}
environment_name: {{deployment.environment_name}}
failures:
{%- for failure in deployment.ymli_data %}
{%- set ns = namespace(d={}) %}
{%- for key, value in failure.items() %}
    {%- if key != "ymli_full_location" and key != "ymli_parent" %}
        {%- set _ = ns.d.update({key: value}) %}
    {%- endif %}
{%- endfor %}
- location: {{failure.ymli_full_location}}
  details: {{ ns.d }}
{%- endfor %}
{% endfor %}