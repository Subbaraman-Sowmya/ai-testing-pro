{
  "_copyright": "Licensed Materials - Property of IBM - (c) Copyright IBM Corporation 2022, 2024. All Rights Reserved. Note to U.S. Government Users Restricted Rights: Use, duplication or disclosure restricted by GSA ADP Schedule Contract with IBM Corp.",
  "scopeName": "source.hlasm",
  "name": "z/VM assembler",
  "fileTypes": ["ASM", "asm", "assemble", "macro", "mac", "repos", "s", "dbd", "mfs", "pcb"],

  "patterns": [
    { "include": "#line-too-long-rule" },
    { "include": "#continuation-line-rule" },
    { "include": "#operation-line-sequence-number-rule" },
    { "include": "#uncontinued-comment-rule" },
    { "include": "#uncontinued-statement-rule" },
    { "include": "#sequence-number-rule" },
    { "include": "#register-variable-rule" },
    { "include": "#register-equate-rule" },
    { "include": "#single-quoted-string-rule" },
    { "include": "#declare-rule" }
  ],

  "repository": {
    "line-too-long-rule": {
      "match": ".*(?<=.{80}).+",
      "name": "invalid.illegal.zvmasm"
    },
    "sequence-number-rule": {
      "match": "[0-9]{8}\\n",
      "name": "comment.line.zvmasm"
    },
    "register-variable-rule": {
      "match": "([R|r][0-9][0-5]?)\\b",
      "name": "keyword.operator.zvmasm"
    },
    "register-equate-rule": {
      "match": "((?i)EQU)[\\s]+([^\\s\"]*)(\".*\"|)([^\\s]*)([^\\s]*)([^@\\n]*)([^@0-9]{2})",
      "captures": {
        "1": {
          "name": "storage.type.zasm"
        },
        "2": {
          "name": "storage.type.zasm"
        },
        "3": {
          "name": "string.quoted.single.zasm"
        },
        "4": {
          "name": "comment.line.zasm"
        },
        "5": {
          "name": "comment.line.zasm"
        },
        "6": {
          "name": "comment.line.zasm"
        },
        "7": {
          "name": "comment.line.zasm"
        },
        "8": {
          "name": "entity.name.tag.zasm"
        }
      },
      "name": "keyword.operator.zasm"
    },
    "single-quoted-string-rule": {
      "match": "(\".*\")",
      "name": "string.quoted.single.zvmasm"
    },
    "uncontinued-comment-rule": {
      "match": "^[.]?[*].*",
      "name": "comment.line.zvmasm"
    },
    "continuation-line-rule": {
      "match": "^[ ]{15}([A-Za-zŽžÀ-ÿ0-9@$#_.&+\\-,=*()\"/\\']+)([ ]+.*)?",
      "captures": {
        "1": {
          "name": "variable.parameter"
        },
        "2": {
          "name": "comment.line.zvmasm"
        }
      }
    },
    "operation-line-sequence-number-rule": {
      "match": "^([A-Za-zŽžÀ-ÿ@$#_.&][A-Za-zŽžÀ-ÿ0-9@$#_.&+\\-,=*()\"/\\']+)?([ ]*)([A-Za-zŽžÀ-ÿ@$#_.&][A-Za-zŽžÀ-ÿ0-9@$#_.&]*)?([ ]+)(\\d{8})",
      "captures": {
        "1": {
          "name": "entity.name.tag.zasm"
        },
        "3": {
          "name": "keyword.control.zvmasm"
        },
        "5": {
          "name": "comment.line.zvmasm"
        }
      }
    },
    "uncontinued-statement-rule": {
      "match": "^([A-Za-zŽžÀ-ÿ@$#_.&][A-Za-zŽžÀ-ÿ0-9@$#_.&+\\-,=*()\"/']*)?([ ]*)([A-Za-zŽžÀ-ÿ@$#_.&][A-Za-zŽžÀ-ÿ0-9@$#_.&*]*)?([ ]*)(('.*'[^ ]*)|(\\(.*\\)\\.[^ ]*)|[^ ]*\\([^)]*\\)[^ ]*('(?:[^']|'')*')[^ ]*|[^ ]*\\([^)]*\\)[^ ]*|[^ ]*,('(?:[^']|'')*')[^ ]*|[^ ]*('\\S(?:[^']|'')*')[^ ]*|[^ ]*('(?:[^']|'')*')[^ ]*|[^ ]+)(.*)",
      "captures": {
        "1": {
          "name": "entity.name.tag.zasm"
        },
        "3": {
          "name": "keyword.control.zvmasm"
        },
        "5": {
          "name": "variable.parameter"
        },
        "6": {
          "name": "string.quoted.single.zvmasm"
        },
        "7": {
          "name": "variable.parameter"
        },
        "8": {
          "name": "string.quoted.single.zvmasm"
        },
        "9": {
          "name": "string.quoted.single.zvmasm"
        },
        "10": {
          "name": "string.quoted.single.zvmasm"
        },
        "11": {
          "name": "string.quoted.single.zvmasm"
        },
        "12": {
          "name": "comment.line.zvmasm"
        }
      }
    },
    "declare-rule": {
      "match": "\\b((?i)D[C|S])[\\s]*([0-9]*|\\(.*\\))([A-Za-zŽžÀ-ÿ][DUBH]?)(L?[0-9]*)(\".*\"|\\s)([^\\s]*)([^@\\n]*)([^@0-9]{2})",
      "captures": {
        "1": {
          "name": "storage.type.zvmasm"
        },
        "2": {
          "name": "storage.type.zvmasm"
        },
        "3": {
          "name": "storage.type.zvmasm"
        },
        "4": {
          "name": "comment.line.zvmasm"
        },
        "5": {
          "name": "string.quoted.single.zvmasm"
        },
        "6": {
          "name": "comment.line.zvmasm"
        },
        "7": {
          "name": "comment.line.zvmasm"
        },
        "8": {
          "name": "entity.name.tag.zvmasm"
        }
      },
      "name": "keyword.operator.zvmasm"
    }
  }
}
